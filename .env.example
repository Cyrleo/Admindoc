# Core Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=false
ALLOWED_HOSTS=api.your-domain.com,your-domain.com
CSRF_TRUSTED_ORIGINS=https://api.your-domain.com,https://your-domain.com

# Security (production)
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# Database (preferred on PaaS)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL_REQUIRE=true

# Database (alternative if DATABASE_URL is not used)
# DB_NAME=admindoc
# DB_USER=admindoc
# DB_PASSWORD=change-me
# DB_HOST=localhost
# DB_PORT=5432

# Email / reminders
DEFAULT_FROM_EMAIL=no-reply@admindoc.local
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=30

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social auth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
SOCIAL_AUTH_GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8000/auth/google/callback/
SOCIAL_AUTH_GITHUB_KEY=
SOCIAL_AUTH_GITHUB_SECRET=

# Comma-separated list of frontend callback URLs allowed by Djoser social auth
DJOSER_SOCIAL_AUTH_ALLOWED_REDIRECT_URIS=https://your-frontend-domain.com/auth/callback

# Bootstrap admin user created by scripts/init_db_defaults.py
INIT_ADMIN_EMAIL=admin@admindoc.local
INIT_ADMIN_PASSWORD=ChangeMeNow!123
INIT_ADMIN_FIRST_NAME=Admin
INIT_ADMIN_LAST_NAME=Root

# Cloud Storage Configuration
CLOUD_STORAGE_ENABLED=true
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUD_STORAGE_ENCRYPTION_KEY=

# Google Drive OAuth (see CLOUD_STORAGE_CONFIG.md for setup instructions)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://api.your-domain.com/api/cloud-storage/oauth/callback/google/

# Microsoft OneDrive OAuth
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=https://api.your-domain.com/api/cloud-storage/oauth/callback/onedrive/

# Dropbox OAuth
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=https://api.your-domain.com/api/cloud-storage/oauth/callback/dropbox/
