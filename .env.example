SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

SOCIAL_AUTH_GITHUB_KEY=
SOCIAL_AUTH_GITHUB_SECRET=

# Comma-separated list of frontend callback URLs allowed by Djoser social auth
DJOSER_SOCIAL_AUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/callback,https://your-frontend-domain.com/auth/callback

# Cloud Storage Configuration
CLOUD_STORAGE_ENABLED=true
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUD_STORAGE_ENCRYPTION_KEY=

# Google Drive OAuth (see CLOUD_STORAGE_CONFIG.md for setup instructions)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/cloud-storage/oauth/callback/google/

# Microsoft OneDrive OAuth (optional, in development)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:8000/api/cloud-storage/oauth/callback/onedrive/

# Dropbox OAuth (optional, in development)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8000/api/cloud-storage/oauth/callback/dropbox/

# PostgreSQL
DB_NAME=easypass_admindoc
DB_USER=easypass
DB_PASSWORD=Bleach  @@  12
DB_HOST=postgresql-easypass.alwaysdata.net
DB_PORT=5432

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / reminders
DEFAULT_FROM_EMAIL=no-reply@admindoc.local
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
